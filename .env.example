# Variables para interpolación en docker-compose.yml (${POSTGRES_*} en el servicio backend).
# DEBEN ser idénticas a POSTGRES_USER, POSTGRES_PASSWORD y POSTGRES_DB en backend/.env
# (si no, el contenedor backend usará una URL distinta a la BD real).
#
# Recomendado (misma fuente que backend/.env):  make sync-root-env
# Manual:  cp .env.example .env  y edita, o  make setup-root-env

POSTGRES_USER=some_user
POSTGRES_PASSWORD=some_password
POSTGRES_DB=optima_db
