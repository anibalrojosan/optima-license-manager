# Database — canonical URL for SQLAlchemy (FastAPI, Alembic). Use one of the examples below.
# API outside of Docker (host: localhost, port: 5436, published in docker-compose: 5436 -> 5432 in the container):
# DATABASE_URL=postgresql://some_user:some_password@localhost:5436/optima_db
# API inside of Docker (db service, internal port 5432):
DATABASE_URL=postgresql://some_user:some_password@db:5432/optima_db

# Variables for the postgres image in the docker-compose (server initialization; do not substitute DATABASE_URL in the app)
POSTGRES_USER=some_user
POSTGRES_PASSWORD=some_password
POSTGRES_DB=optima_db

# Security (JWT)
SECRET_KEY=generate-a-safe-key-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
